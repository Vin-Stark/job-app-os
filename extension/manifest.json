{
  "manifest_version": 3,
  "name": "Job App OS — Capture & Tailor",
  "version": "0.2.2",
  "description": "Capture a job posting, gate it on eligibility, and drag a tailored resume straight into the application.",
  "key": "",
  "action": {
    "default_title": "Job App OS",
    "default_icon": {
      "16": "public/icons/icon16.png",
      "48": "public/icons/icon48.png",
      "128": "public/icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "src/popup/index.html"
  },
  "background": {
    "service_worker": "src/background/sw.ts",
    "type": "module"
  },
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "storage",
    "sidePanel"
  ],
  "host_permissions": [
    "http://localhost:5001/*",
    "http://localhost:5173/*"
  ],
  "optional_host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://localhost:5173/*"
      ],
      "js": [
        "src/content/tokenSync.ts"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "public/icons/icon16.png",
    "48": "public/icons/icon48.png",
    "128": "public/icons/icon128.png"
  }
}
